const express = require('express');
const cors = require('cors');
const { OpenAI } = require('openai');
require('dotenv').config();

const app = express();

// הגדרות אבטחה - מאפשר לאתר שלך ב-cPanel לפנות לשרת הזה
app.use(cors({
    origin: '*' // בעתיד כדאי לשנות לכתובת האתר האמיתית שלך
}));
app.use(express.json());

// משיכת מפתח ה-API של OpenAI מהגדרות הסביבה ששמנו ב-Render
const openai = new OpenAI({
    apiKey: process.env.OPENAI_API_KEY,
});

const SYSTEM_PROMPT = `אתה יועץ משפטי מומחה בתחום חדלות פרעון.
ענה תמיד בעברית בלבד. התבסס על המידע המצורף (אם יש).`;

// הנתיב שאליו האתר שלך ישלח את השאלות
app.post('/api/chat', async (req, res) => {
    try {
        const { question, history } = req.body;

        if (!question) {
            return res.status(400).json({ error: "No question provided" });
        }

        /* ===============================================================
        כאן בעתיד יכנס הקוד של ה-RAG (חיבור לקבצי ה-PDF)
        =============================================================== */

        // סידור היסטוריית השיחה לפורמט ש-OpenAI מבין
        const formattedHistory = (history || []).map(msg => ({
            role: msg.role === 'bot' ? 'assistant' : 'user',
            content: msg.content
        }));

        // בניית מערך ההודעות השלם כולל הנחיות המערכת
        const messages = [
            { role: "system", content: SYSTEM_PROMPT },
            ...formattedHistory,
            { role: "user", content: question }
        ];

        // פניה למודל של OpenAI 
        const response = await openai.chat.completions.create({
            model: "gpt-4o", // המודל החכם ביותר כרגע
            messages: messages,
        });

        res.json({ reply: response.choices[0].message.content });

    } catch (error) {
        console.error("Error calling OpenAI API:", error);
        res.status(500).json({ error: "Internal Server Error", details: error.message });
    }
});

// בדיקה שהשרת חי
app.get('/health', (req, res) => {
    res.send("OpenAI Server is running smoothly! 🟢");
});

// הפעלת השרת
const PORT = process.env.PORT || 10000;
app.listen(PORT, () => {
    console.log(`Server is running on port ${PORT}`);
});});
